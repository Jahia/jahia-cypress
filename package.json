{
  "name": "@jahia/cypress",
  "version": "6.4.2",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src -c .eslintrc.json --ext .ts --max-warnings=0",
    "e2e:ci": "cypress run",
    "e2e:debug": "cypress open",
    "report:merge": "mochawesome-merge results/reports/cypress*.json > results/reports/report.json && rm results/reports/cypress*.json",
    "report:html": "marge --inline results/reports/report.json --reportDir results/reports/"
  },
  "bin": {
    "ci.build": "./ci.build.sh",
    "ci.startup": "./ci.startup.sh",
    "env.debug": "./env.debug.sh",
    "env.run": "./env.run.sh"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@jahia/eslint-config": "^2.1.2",
    "@jahia/jahia-reporter": "^1.1.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^5.2.0",
    "@typescript-eslint/parser": "^5.2.0",
    "cross-fetch": "^3.1.5",
    "cypress": "15.7.0",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-wait-until": "^3.0.2",
    "eslint": "^8.51.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "mocha-junit-reporter": "^2.0.2",
    "mochawesome": "^6.3.1",
    "mochawesome-merge": "^4.2.0",
    "mochawesome-report-generator": "^5.2.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@apollo/client": "^3.4.9",
    "cypress-real-events": "^1.14.0",
    "graphql": "^15.5.0",
    "graphql-tag": "^2.11.0"
  },
  "packageManager": "yarn@4.12.0"
}
